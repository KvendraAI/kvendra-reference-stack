# SPDX-License-Identifier: MIT
# kvendra-reference-stack — env example
#
# Copy to `.env` and adapt. `.env` is in .gitignore — never commit secrets.
#
# Three modes (see docs/modes.md):
#   Cloud  (default) — embeddings via api.kvendra.cloud (free 200k tok/month).
#                      No Ollama container needed. Just paste your API key.
#   Ollama (opt-in)  — everything local. Start with `--with-ollama` or
#                      `docker compose --profile ollama up -d`.
#   Mock   (CI/dev)  — deterministic test vectors, no external calls.
#
# The default in this file is **Cloud mode** with a placeholder API key.
# Sign up at https://kvendra.cloud to get your real key (free tier).

# =============================================================================
# Postgres (kvendra-db)
# =============================================================================
POSTGRES_USER=kvendra
POSTGRES_PASSWORD=kvendra
POSTGRES_DB=kvendra_platform

# =============================================================================
# Platform (kvendra-platform)
# =============================================================================
PLATFORM_HOST_PORT=7777
LOG_LEVEL=info
STAGE=local

# --- Embeddings provider --------------------------------------------------
# Allowed values: mock | openai-compatible | bedrock
#   mock              — deterministic test vectors, no external calls.
#   openai-compatible — Ollama, vLLM, llama.cpp, OpenAI cloud, kvendra.cloud, ...
#   bedrock           — NOT available in this stack (AGPL boundary; ADR-KVD-1823F7).
#
# Active defaults: Cloud mode (api.kvendra.cloud).
# Replace EMBEDDINGS_API_KEY with your real key from https://kvendra.cloud
EMBEDDINGS_PROVIDER=openai-compatible
EMBEDDINGS_BASE_URL=https://api.kvendra.cloud/v1
EMBEDDINGS_MODEL=kvendra-embedding-v1
EMBEDDINGS_API_KEY=REPLACE_WITH_YOUR_KVENDRA_KEY

# --- Alternative mode: Ollama local (uncomment to use) -----------------------
# Start the stack with `./scripts/up.sh --with-ollama` (or
# `docker compose --profile ollama up -d`) so the kvendra-ollama service
# is created, then point embeddings at it:
# EMBEDDINGS_PROVIDER=openai-compatible
# EMBEDDINGS_BASE_URL=http://kvendra-ollama:11434/v1
# EMBEDDINGS_MODEL=mxbai-embed-large
# # No EMBEDDINGS_API_KEY needed for local Ollama.

# --- Alternative mode: mock (CI / dev) ---------------------------------------
# EMBEDDINGS_PROVIDER=mock
# EMBEDDINGS_BASE_URL=
# EMBEDDINGS_MODEL=
# EMBEDDINGS_API_KEY=

EMBEDDINGS_TIMEOUT_MS=30000

# =============================================================================
# Ollama runtime (kvendra-ollama) — only used when the `ollama` profile is on
# =============================================================================
OLLAMA_HOST_PORT=11434

# Models pulled at first startup by ./scripts/up.sh --with-ollama.
# Comma-separated list. Empty = no pull (you do it manually with `ollama pull`).
# Heads-up: each model is 1–10 GB. The defaults are the recommended baseline.
OLLAMA_MODELS_PRELOAD=llama3.1:8b,mxbai-embed-large

# =============================================================================
# Backup sidecar (kvendra-backup)
# =============================================================================
# Cron syntax: minute hour dom month dow
# Default: daily at 03:30 (container TZ = UTC unless you mount /etc/timezone).
BACKUP_CRON="30 3 * * *"
BACKUP_RETENTION_DAYS=14
