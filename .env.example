# SPDX-License-Identifier: MIT
# kvendra-reference-stack — env example
#
# Copy to `.env` and adapt. `.env` is in .gitignore — never commit secrets.
#
# Three modes (see docs/tier-a-b-c.md):
#   Tier A — hybrid L1: embeddings from kvendra.cloud, LLM from local Ollama.
#   Tier B — self-hosted full: everything local (Ollama for embeddings AND LLM).
#   Tier C — managed SaaS: not this stack — see kvendra.com/enterprise.
#
# The default in this file is the **mock provider** so `docker compose up` works
# on a cold box without pulling models. Switch to a real provider once you've
# pulled an Ollama embedding model or registered for a kvendra.cloud key.

# =============================================================================
# Postgres (kvendra-db)
# =============================================================================
POSTGRES_USER=kvendra
POSTGRES_PASSWORD=kvendra
POSTGRES_DB=kvendra_platform

# =============================================================================
# Platform (kvendra-platform)
# =============================================================================
PLATFORM_HOST_PORT=7777
LOG_LEVEL=info
STAGE=local

# --- Embeddings provider --------------------------------------------------
# Allowed values: mock | openai-compatible | bedrock
#   mock              — deterministic test vectors, no external calls. Default.
#   openai-compatible — Ollama, vLLM, llama.cpp, OpenAI cloud, kvendra.cloud, ...
#   bedrock           — NOT available in this stack (AGPL boundary; ADR-KVD-1823F7).
EMBEDDINGS_PROVIDER=mock

# --- Tier B example (uncomment to use local Ollama) -----------------------
# EMBEDDINGS_PROVIDER=openai-compatible
# EMBEDDINGS_BASE_URL=http://kvendra-ollama:11434/v1
# EMBEDDINGS_MODEL=mxbai-embed-large
# # No EMBEDDINGS_API_KEY needed for local Ollama.

# --- Tier A example (uncomment to use kvendra.cloud) ----------------------
# EMBEDDINGS_PROVIDER=openai-compatible
# EMBEDDINGS_BASE_URL=https://api.kvendra.com/v1
# EMBEDDINGS_MODEL=kvendra-embedding-v1
# EMBEDDINGS_API_KEY=<your-key-from-app.kvendra.cloud>

EMBEDDINGS_TIMEOUT_MS=30000

# =============================================================================
# Ollama (kvendra-ollama)
# =============================================================================
OLLAMA_HOST_PORT=11434

# Models pulled at first startup by ./scripts/up.sh.
# Comma-separated list. Empty = no pull (you do it manually with `ollama pull`).
# Heads-up: each model is 1–10 GB. The defaults are the recommended baseline.
OLLAMA_MODELS_PRELOAD=llama3.1:8b,mxbai-embed-large

# =============================================================================
# Backup sidecar (kvendra-backup)
# =============================================================================
# Cron syntax: minute hour dom month dow
# Default: daily at 03:30 (container TZ = UTC unless you mount /etc/timezone).
BACKUP_CRON=30 3 * * *
BACKUP_RETENTION_DAYS=14
